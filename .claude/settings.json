{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install*)",
      "Bash(npm i*)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run start)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npx prisma migrate dev*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma studio)",
      "Bash(npx prisma db pull)",
      "Bash(npx prisma format)",
      "Bash(docker compose up*)",
      "Bash(docker compose down)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs*)",
      "Bash(curl http://localhost*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(node --version)",
      "Bash(ls*)",
      "Bash(cat ./README*)",
      "Bash(cat ./CLAUDE*)",
      "Bash(cat ./ARCHITECTURE*)",
      "Read(./backend/**)",
      "Read(./frontend/**)",
      "Read(./*.md)",
      "Write(./backend/src/**)",
      "Write(./backend/prisma/schema.prisma)",
      "Write(./frontend/src/**)",
      "Edit(./backend/src/**)",
      "Edit(./backend/prisma/schema.prisma)",
      "Edit(./frontend/src/**)",
      "Edit(./*.md)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./.env.*)",
      "Read(./**/.env.*)",
      "Read(./node_modules/**)",
      "Read(./**/secrets/**)",
      "Write(./.env*)",
      "Write(./**/.env*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(docker compose down -v)",
      "Bash(npx prisma db push*)",
      "Bash(npx prisma migrate reset*)",
      "Bash(sudo*)"
    ]
  },
  "_note": "Read về cấu trúc settings.json: https://docs.claude.com/en/docs/claude-code/settings"
}