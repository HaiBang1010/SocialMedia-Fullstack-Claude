# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (khớp với docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/social_media?schema=public"

# JWT secrets (TUYỆT ĐỐI đổi trong production - dùng random 64 ký tự)
JWT_ACCESS_SECRET="dev-access-secret-change-me-please-make-it-random"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-please-make-it-random"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (frontend URL)
CORS_ORIGIN="http://localhost:5173"

# ─── Storage (MinIO) ───
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=social-media-media
S3_PUBLIC_URL=http://localhost:9000/social-media-media

# Giphy API Key (https://developers.giphy.com/)
GIPHY_API_KEY=your_giphy_api_key_here