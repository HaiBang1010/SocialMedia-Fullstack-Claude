// Phase 2: User + Post + PostMedia + Follow + Like + Comment
// Các model khác (Story, Message, AudioTrack...) sẽ thêm ở các phase sau

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  name         String
  bio          String?  @db.VarChar(160)
  avatarUrl    String?
  isPrivate    Boolean  @default(false)
  lastSeenAt   DateTime? // Phase 5.2 — set on socket disconnect; powers presence "last seen"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts        Post[]
  comments     Comment[]
  likes        Like[]
  stories      Story[]
  storyViews   StoryView[]
  sentMessages Message[]
  conversations Participant[]
  // Follow relation naming is intentionally "inverted" (matches ARCHITECTURE §3):
  // - followers: rows where I am the `following` target  -> people who follow ME
  // - following: rows where I am the `follower`          -> people I follow
  followers    Follow[] @relation("following")
  following    Follow[] @relation("follower")

  @@index([username])
  @@index([email])
}

model Post {
  id         String         @id @default(cuid())
  authorId   String
  caption    String?        @db.Text
  visibility PostVisibility @default(PUBLIC)
  createdAt  DateTime       @default(now())

  author   User        @relation(fields: [authorId], references: [id])
  media    PostMedia[]
  comments Comment[]
  likes    Like[]

  @@index([authorId, createdAt])
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

model PostMedia {
  id           String    @id @default(cuid())
  postId       String
  type         MediaType
  url          String // publicUrl from presign response
  objectKey    String // S3 key, used to DeleteObject when the post is deleted
  thumbnailUrl String? // video poster URL (frontend-extracted), null for images
  thumbnailObjectKey String? // S3 key of the thumbnail, used to DeleteObject alongside the video
  duration     Int? // video length in seconds, null for images
  order        Int       @default(0)
  width        Int?
  height       Int?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum MediaType {
  IMAGE
  VIDEO
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // "follower"  = the user who follows; "following" = the user being followed.
  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId]) // followers-list + isFollowing lookup keyed by target
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String? // stored in DB; Phase 2 UI renders flat (nested arrives Phase 3)
  content   String   @db.Text
  createdAt DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("replies")

  @@index([postId, createdAt])
}

// Phase 4.1 — Stories. One story = ONE media (fields flat on the row, no child table
// like PostMedia). 24h ephemeral: expiresAt = createdAt + 24h, active = expiresAt > now
// && !isArchived. No per-story visibility column — privacy is enforced at the user level
// (a private account hides its stories from non-followers). StoryItem (overlays) and
// AudioTrack are deferred (Phase 4.3/4.4), so this model does NOT reference them yet.
model Story {
  id                 String    @id @default(cuid())
  authorId           String
  mediaUrl           String // publicUrl from presign response
  mediaObjectKey     String // S3 key, used to DeleteObject when the story is deleted/expired
  mediaType          MediaType
  thumbnailUrl       String? // video poster URL (frontend-extracted), null for images
  thumbnailObjectKey String? // S3 key of the poster, deleted alongside the video
  duration           Int? // video length in seconds, null for images
  width              Int?
  height             Int?
  expiresAt          DateTime // backend sets to createdAt + 24h
  isArchived         Boolean   @default(false) // flipped by the expiry cron (Phase 4.4)
  createdAt          DateTime  @default(now())

  author User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views  StoryView[]
  items  StoryItem[] // Phase 4.3 — overlays (text/emoji now, mention/sticker/tag later)

  @@index([authorId, expiresAt]) // active-by-author query
  @@index([isArchived, expiresAt]) // expiry cron sweep (Phase 4.4)
}

// Phase 4.3 — Story overlays. Each item is one draggable layer (text, emoji, …)
// positioned with x/y normalized 0-1 relative to the story content zone. scale/rotation
// are stored (default 1/0) but only TEXT + EMOJI with drag are wired in 4.3a; multi-touch
// scale/rotate + MENTION/STICKER/TAG arrive in 4.3b. payload is a small per-type JSON blob.
model StoryItem {
  id       String        @id @default(cuid())
  storyId  String
  type     StoryItemType
  x        Float // 0-1 relative position (content-zone normalized)
  y        Float
  scale    Float         @default(1) // 4.3a always 1 (multi-touch scale → 4.3b)
  rotation Float         @default(0) // 4.3a always 0 (rotate → 4.3b)
  payload  Json // TEXT: { text }  EMOJI: { emoji }

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

enum StoryItemType {
  TEXT // Phase 4.3a
  EMOJI // Phase 4.3a
  MENTION // Phase 4.3b
  STICKER // Phase 4.3b
  TAG // Phase 4.3b
}

model StoryView {
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId]) // one view row per (story, viewer) — upsert keeps it idempotent
  @@index([viewerId]) // "have I seen these stories" batch lookup
  @@index([storyId, viewedAt(sort: Desc)]) // viewers-list cursor pagination (Phase 4.4)
}

// Phase 5.1 — Messaging. A conversation is either a 1-1 DIRECT chat or a named GROUP.
// directKey makes the find-or-create of a DIRECT conversation race-safe via a UNIQUE
// constraint (sorted "userA:userB"); GROUP rows leave it null. lastMessageAt is a
// denormalized copy of the newest message's createdAt, bumped on every send, so the
// conversation list can order by recent activity with a plain cursor query (no parent-by-
// child-aggregate ordering, which Prisma can't express cleanly).
model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType
  directKey     String?          @unique // sorted "userA:userB" for DIRECT; null for GROUP
  name          String? // GROUP only
  avatarUrl     String? // GROUP only
  lastMessageAt DateTime         @default(now()) // newest-message timestamp, for list ordering
  createdAt     DateTime         @default(now())

  participants Participant[]
  messages     Message[]

  @@index([lastMessageAt]) // conversation-list ordering
}

enum ConversationType {
  DIRECT
  GROUP
}

// Phase 5.1 — membership join table. Composite PK keeps one row per (conversation, user)
// and makes membership lookups O(1). lastReadMessageId backs unread tracking (read-receipt
// UI arrives in Phase 5.3). isAdmin is set for the group creator.
model Participant {
  conversationId    String
  userId            String
  joinedAt          DateTime @default(now())
  lastReadMessageId String? // last message this user has read (read receipts → Phase 5.3)
  isAdmin           Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@index([userId]) // "conversations I'm in" lookup
}

// Phase 5.1 — a single message. contentType is declared with the full set for forward
// compatibility (mirrors StoryItemType's all-5 declaration in 4.3a), but Zod gates it to
// TEXT in 5.1. replyToId / sharedPostId are scalar-only reference columns (no FK relation
// yet — like Notification.postId/commentId), wired up when reply-to-message and post-share
// land in Phase 5.5. deletedAt is the soft-delete (recall) marker, also Phase 5.5.
model Message {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String
  contentType    MessageContentType
  content        String?            @db.Text
  replyToId      String? // reply-to-message reference (relation wired in Phase 5.5)
  sharedPostId   String? // shared-post reference (relation wired in Phase 5.5)
  deletedAt      DateTime? // soft-delete / recall marker (Phase 5.5)
  createdAt      DateTime           @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt]) // message-list cursor (newest-first)
}

enum MessageContentType {
  TEXT // Phase 5.1
  EMOJI // Phase 5.4
  POST_SHARE // Phase 5.5
  VOICE // Phase 5.4
  IMAGE // Phase 5.4
  VIDEO // Phase 5.4
  STICKER // Phase 5.4
  GIF // Phase 5.4
}
