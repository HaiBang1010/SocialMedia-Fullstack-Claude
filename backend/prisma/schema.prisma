// Phase 2: User + Post + PostMedia + Follow + Like + Comment
// Các model khác (Story, Message, AudioTrack...) sẽ thêm ở các phase sau

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  name         String
  bio          String?  @db.VarChar(160)
  avatarUrl    String?
  isPrivate    Boolean  @default(false)
  lastSeenAt   DateTime? // Phase 5.2 — set on socket disconnect; powers presence "last seen"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts        Post[]
  comments     Comment[]
  likes        Like[]
  stories      Story[]
  storyViews   StoryView[]
  sentMessages Message[]
  conversations Participant[]
  messageReactions MessageReaction[]
  initiatedCalls Call[] @relation("initiatedCalls") // Phase 6 — calls this user started
  notifications      Notification[] @relation("recipient") // Phase 7 — notifications I received
  actedNotifications Notification[] @relation("actor")     // Phase 7 — notifications I triggered
  // Follow relation naming is intentionally "inverted" (matches ARCHITECTURE §3):
  // - followers: rows where I am the `following` target  -> people who follow ME
  // - following: rows where I am the `follower`          -> people I follow
  followers    Follow[] @relation("following")
  following    Follow[] @relation("follower")

  // Phase 7 — full-text search over username + name (see Post.searchVector note; DDL hand-written).
  searchVector Unsupported("tsvector")?

  @@index([username])
  @@index([email])
}

model Post {
  id         String         @id @default(cuid())
  authorId   String
  caption    String?        @db.Text
  visibility PostVisibility @default(PUBLIC)
  createdAt  DateTime       @default(now())

  author   User        @relation(fields: [authorId], references: [id])
  media    PostMedia[]
  comments Comment[]
  likes    Like[]
  sharedInMessages Message[] @relation("SharedPost") // Phase 5.4c — messages that share this post

  // Phase 7 — full-text search. GENERATED ALWAYS column (DDL hand-written in the
  // add_search_vectors migration; Prisma can't author the GENERATED expression). Declared
  // Unsupported only to silence drift detection; it is excluded from the typed client and never
  // selected/serialized — search reads it via $queryRaw.
  searchVector Unsupported("tsvector")?

  @@index([authorId, createdAt])
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

model PostMedia {
  id           String    @id @default(cuid())
  postId       String
  type         MediaType
  url          String // publicUrl from presign response
  objectKey    String // S3 key, used to DeleteObject when the post is deleted
  thumbnailUrl String? // video poster URL (frontend-extracted), null for images
  thumbnailObjectKey String? // S3 key of the thumbnail, used to DeleteObject alongside the video
  duration     Int? // video length in seconds, null for images
  order        Int       @default(0)
  width        Int?
  height       Int?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum MediaType {
  IMAGE
  VIDEO
  VOICE // Phase 5.4b — voice message audio (MessageMedia only; no thumbnail/dimensions)
  STICKER // Phase 5.4c — Giphy sticker (MessageMedia only; third-party URL, no objectKey/thumbnail)
  GIF // Phase 5.4c — Giphy GIF (MessageMedia only; third-party URL, no objectKey/thumbnail)
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // "follower"  = the user who follows; "following" = the user being followed.
  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId]) // followers-list + isFollowing lookup keyed by target
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String? // stored in DB; Phase 2 UI renders flat (nested arrives Phase 3)
  content   String   @db.Text
  createdAt DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("replies")

  @@index([postId, createdAt])
}

// Phase 4.1 — Stories. One story = ONE media (fields flat on the row, no child table
// like PostMedia). 24h ephemeral: expiresAt = createdAt + 24h, active = expiresAt > now
// && !isArchived. No per-story visibility column — privacy is enforced at the user level
// (a private account hides its stories from non-followers). StoryItem (overlays) and
// AudioTrack are deferred (Phase 4.3/4.4), so this model does NOT reference them yet.
model Story {
  id                 String    @id @default(cuid())
  authorId           String
  mediaUrl           String // publicUrl from presign response
  mediaObjectKey     String // S3 key, used to DeleteObject when the story is deleted/expired
  mediaType          MediaType
  thumbnailUrl       String? // video poster URL (frontend-extracted), null for images
  thumbnailObjectKey String? // S3 key of the poster, deleted alongside the video
  duration           Int? // video length in seconds, null for images
  width              Int?
  height             Int?
  expiresAt          DateTime // backend sets to createdAt + 24h
  isArchived         Boolean   @default(false) // flipped by the expiry cron (Phase 4.4)
  createdAt          DateTime  @default(now())

  author User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views  StoryView[]
  items  StoryItem[] // Phase 4.3 — overlays (text/emoji now, mention/sticker/tag later)

  @@index([authorId, expiresAt]) // active-by-author query
  @@index([isArchived, expiresAt]) // expiry cron sweep (Phase 4.4)
}

// Phase 4.3 — Story overlays. Each item is one draggable layer (text, emoji, …)
// positioned with x/y normalized 0-1 relative to the story content zone. scale/rotation
// are stored (default 1/0) but only TEXT + EMOJI with drag are wired in 4.3a; multi-touch
// scale/rotate + MENTION/STICKER/TAG arrive in 4.3b. payload is a small per-type JSON blob.
model StoryItem {
  id       String        @id @default(cuid())
  storyId  String
  type     StoryItemType
  x        Float // 0-1 relative position (content-zone normalized)
  y        Float
  scale    Float         @default(1) // 4.3a always 1 (multi-touch scale → 4.3b)
  rotation Float         @default(0) // 4.3a always 0 (rotate → 4.3b)
  payload  Json // TEXT: { text }  EMOJI: { emoji }

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

enum StoryItemType {
  TEXT // Phase 4.3a
  EMOJI // Phase 4.3a
  MENTION // Phase 4.3b
  STICKER // Phase 4.3b
  TAG // Phase 4.3b
}

model StoryView {
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId]) // one view row per (story, viewer) — upsert keeps it idempotent
  @@index([viewerId]) // "have I seen these stories" batch lookup
  @@index([storyId, viewedAt(sort: Desc)]) // viewers-list cursor pagination (Phase 4.4)
}

// Phase 5.1 — Messaging. A conversation is either a 1-1 DIRECT chat or a named GROUP.
// directKey makes the find-or-create of a DIRECT conversation race-safe via a UNIQUE
// constraint (sorted "userA:userB"); GROUP rows leave it null. lastMessageAt is a
// denormalized copy of the newest message's createdAt, bumped on every send, so the
// conversation list can order by recent activity with a plain cursor query (no parent-by-
// child-aggregate ordering, which Prisma can't express cleanly).
model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType
  directKey     String?          @unique // sorted "userA:userB" for DIRECT; null for GROUP
  name          String? // GROUP only
  avatarUrl     String? // GROUP only
  lastMessageAt DateTime         @default(now()) // newest-message timestamp, for list ordering
  createdAt     DateTime         @default(now())

  participants Participant[]
  messages     Message[]
  calls        Call[] // Phase 6 — calls placed in this conversation

  @@index([lastMessageAt]) // conversation-list ordering
}

enum ConversationType {
  DIRECT
  GROUP
}

// Phase 5.1 — membership join table. Composite PK keeps one row per (conversation, user)
// and makes membership lookups O(1). lastReadMessageId backs unread tracking (read-receipt
// UI arrives in Phase 5.3). isAdmin is set for the group creator.
model Participant {
  conversationId    String
  userId            String
  joinedAt          DateTime @default(now())
  lastReadMessageId String? // last message this user has read (read receipts → Phase 5.3)
  isAdmin           Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@index([userId]) // "conversations I'm in" lookup
}

// Phase 5.1 — a single message. contentType is declared with the full set for forward
// compatibility (mirrors StoryItemType's all-5 declaration in 4.3a). replyToId stays a
// scalar-only reference column (no FK relation yet — like Notification.postId/commentId),
// wired up when reply-to-message lands in Phase 5.5. sharedPostId got its FK relation
// (sharedPost) in Phase 5.4c (post-share). deletedAt is the soft-delete (recall) marker (5.5).
model Message {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String
  contentType    MessageContentType
  content        String?            @db.Text
  replyToId      String? // reply-to-message reference (relation wired in Phase 5.5)
  sharedPostId   String? // shared-post reference (FK relation `sharedPost` wired in Phase 5.4c)
  callId         String? // Phase 6 — CALL entry reference (FK relation `call` below)
  deletedAt      DateTime? // soft-delete / recall marker (Phase 5.5)
  createdAt      DateTime           @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  reactions    MessageReaction[]
  media        MessageMedia[] // Phase 5.4a — image/video attachments (1..10, ordered)
  sharedPost   Post?         @relation("SharedPost", fields: [sharedPostId], references: [id], onDelete: SetNull) // Phase 5.4c — post-share preview; SetNull so the message survives a deleted post
  call         Call?         @relation(fields: [callId], references: [id], onDelete: SetNull) // Phase 6 — CALL entry; SetNull mirrors sharedPost

  @@index([conversationId, createdAt]) // message-list cursor (newest-first)
}

// Phase 5.4a — image/video attachments of a message (1..10 per message, mix allowed). One
// row = one media item. Mirrors PostMedia/Story media fields: objectKey + thumbnailObjectKey
// are kept so the S3 objects can be cleaned up on recall (Phase 5.5); width/height drive the
// IG-style grid layout (avoid CLS); order is the 0-indexed carousel position. The message's
// contentType is derived server-side (mix → IMAGE marker); render is per-item via `type`.
model MessageMedia {
  id                 String    @id @default(cuid())
  messageId          String
  type               MediaType // reuse the existing IMAGE/VIDEO enum
  order              Int       @default(0) // 0-indexed carousel order
  url                String // publicUrl from presign response (original); for STICKER/GIF this is the Giphy CDN URL
  objectKey          String? // S3 key of the original (recall cleanup); null for STICKER/GIF (Giphy-hosted, Phase 5.4c)
  thumbnailUrl       String? // image thumbnail / video poster (frontend-generated)
  thumbnailObjectKey String? // S3 key of the thumbnail, deleted alongside the media
  width              Int?
  height             Int?
  duration           Int? // video length in seconds, null for images

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, order]) // one media per (message, order); leftmost-messageId indexes the lookup
}

// Phase 5.3a — one emoji reaction per (message, user). Composite PK enforces "1 reaction per
// user per message" (a new emoji replaces the old via upsert). The emoji is gated to a 7-item
// whitelist at the Zod layer (messages.schema.ts), kept open as a String column. Both relations
// cascade on delete — mirrors Like / StoryView, so a deleted message or user takes its
// reactions with it (no orphan rows).
model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId]) // 1 reaction per user per message; leftmost-messageId indexes the lookup
}

enum MessageContentType {
  TEXT // Phase 5.1
  EMOJI // Phase 5.4
  POST_SHARE // Phase 5.5
  VOICE // Phase 5.4
  IMAGE // Phase 5.4
  VIDEO // Phase 5.4
  STICKER // Phase 5.4
  GIF // Phase 5.4
  CALL // Phase 6 — audio/video call event (renders as CallEntry in the thread)
}

// Phase 6 — one audio/video call. Recorded as a row AND surfaced in the thread via a Message
// (contentType CALL, Message.callId FK) — mirrors the Phase 5.4c sharedPost infrastructure, so
// pagination / list-preview / realtime / optimistic all come for free. The LiveKit room name is
// the Call id itself (Decision 9 — no separate column). endedAt null = still ringing/ongoing;
// endedReason records WHY it ended (Decision 3). Modeled 1-to-many (messages) to mirror
// Post.sharedInMessages and dodge Prisma's @unique-on-1-1 requirement; 1-1 in practice.
model Call {
  id             String         @id @default(cuid())
  conversationId String
  initiatorId    String
  type           CallType
  startedAt      DateTime       @default(now())
  endedAt        DateTime? // null while ringing/ongoing
  endedReason    CallEndReason? // why the call ended (null while active)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator    User         @relation("initiatedCalls", fields: [initiatorId], references: [id])
  messages     Message[] // the CALL entry/entries that reference this call (1 in practice)

  @@index([conversationId, startedAt])
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallEndReason {
  COMPLETED
  MISSED
  DECLINED
  FAILED
}

// Phase 7 — a notification row for the 3 stored social events (LIKE / COMMENT / FOLLOW).
// MESSAGE + CALL are intentionally NOT persisted here — they are covered by the per-conversation
// unread badge + existing realtime sockets (Decisions D1/D2). `actor` is a real FK relation (the
// list always renders the actor's avatar + username); `postId`/`commentId` stay scalar-only
// references (no FK) — the client builds the deep-link from them, mirroring Message.replyToId.
// readAt null = unread (powers the badge count). Dedupe (same recipient+actor+type+ref within 1h)
// happens at the service layer, NOT via a unique constraint (the key includes a time window).
model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String
  type        NotificationType
  postId      String? // scalar reference (LIKE/COMMENT) — no FK relation
  commentId   String? // scalar reference (COMMENT)      — no FK relation
  readAt      DateTime? // null = unread
  createdAt   DateTime         @default(now())

  recipient User @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User @relation("actor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt(sort: Desc)]) // notification list (newest-first cursor)
  @@index([recipientId, readAt]) // unread-count lookup
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
}
