// Phase 1: chỉ User model
// Các model khác (Post, Story, Message...) sẽ thêm ở các phase sau

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  name         String
  bio          String?  @db.VarChar(160)
  avatarUrl    String?
  isPrivate    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([username])
  @@index([email])
}
